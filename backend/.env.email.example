# ResolveAI - configuracoes de email para recuperacao de senha
# Copie os valores desejados para o backend/.env local ou para o Render.

# Em producao, deixe 0 para nao expor o codigo de recuperacao na resposta da API.
EXPOSE_RESET_TOKEN=0

# Modo recomendado para Render free: API HTTP
EMAIL_DELIVERY_METHOD=api
EMAIL_API_PROVIDER=resend
EMAIL_API_KEY=re_seu_token
EMAIL_FROM_EMAIL=onboarding@resend.dev
EMAIL_FROM_NAME=ResolveAI
EMAIL_REPLY_TO=

# Se preferir SMTP em outro ambiente, troque para:
# EMAIL_DELIVERY_METHOD=smtp

# SMTP presets suportados:
# gmail, outlook, hotmail, live, yahoo, zoho, protonmail, custom
SMTP_PROVIDER=gmail
SMTP_USERNAME=seu-email@provedor.com
SMTP_PASSWORD=sua-senha-ou-app-password
SMTP_FROM_EMAIL=seu-email@provedor.com
SMTP_FROM_NAME=ResolveAI

# Para custom, preencha manualmente:
SMTP_HOST=
SMTP_PORT=
SMTP_USE_TLS=
SMTP_USE_SSL=
